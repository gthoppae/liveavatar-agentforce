# ===== REQUIRED =====

# HeyGen LiveAvatar
LIVEAVATAR_API_KEY=          # API key from liveavatar.com
LIVEAVATAR_AVATAR_ID=        # Avatar ID from LiveAvatar dashboard
LIVEAVATAR_VOICE_ID=         # Voice ID from LiveAvatar dashboard

# Salesforce Agentforce
SF_INSTANCE_URL=https://your-org.my.salesforce.com
SF_CLIENT_ID=                # Connected App Consumer Key
SF_CLIENT_SECRET=            # Connected App Consumer Secret
SF_AGENT_ID=                 # Agentforce Agent ID

# ===== OPTIONAL =====

# LiveAvatar Configuration
LIVEAVATAR_API_URL=https://api.liveavatar.com  # Override only for staging/testing
LIVEAVATAR_CONTEXT_ID=       # Context ID for FULL mode (avatar personality/knowledge)
LIVEAVATAR_MODE=full         # 'full' (HeyGen built-in TTS) or 'custom' (external TTS)
LIVEAVATAR_LANGUAGE=en       # Language code: en, nl, fr, etc.

# Text-to-Speech (required only for CUSTOM mode)
TTS_PROVIDER=openai          # 'openai' or 'elevenlabs'
OPENAI_API_KEY=              # Required for OpenAI TTS
ELEVENLABS_API_KEY=          # Required if TTS_PROVIDER=elevenlabs
ELEVENLABS_VOICE_ID=         # Required if TTS_PROVIDER=elevenlabs

# Admin Panel
ADMIN_PASSWORD=              # Password for /admin page (leave empty to disable admin)

# API Security
API_SECRET=                  # If set, all API routes require this as Bearer token or x-api-key header

# Heroku-only (for admin config management via Heroku Platform API)
HEROKU_API_KEY=              # Heroku Platform API token
HEROKU_APP_NAME=             # Heroku app name

# App URL (SSR fallback — browser uses window.location.origin automatically)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default UI (overridable via URL params)
NEXT_PUBLIC_DEFAULT_SITE=    # e.g., 'mycustomer'
NEXT_PUBLIC_DEFAULT_LANG=    # e.g., 'nl'
