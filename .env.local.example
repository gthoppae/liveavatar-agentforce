# ===== REQUIRED =====

# HeyGen LiveAvatar — get credentials from liveavatar.com
LIVEAVATAR_API_KEY=
LIVEAVATAR_AVATAR_ID=
LIVEAVATAR_VOICE_ID=

# Salesforce Agentforce — Connected App with Client Credentials flow
SF_INSTANCE_URL=
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_AGENT_ID=

# ===== OPTIONAL =====

# LiveAvatar Configuration
# Override only for staging/testing (default: https://api.liveavatar.com)
LIVEAVATAR_API_URL=
# Context ID for FULL mode (avatar personality/knowledge)
LIVEAVATAR_CONTEXT_ID=
# 'full' (HeyGen built-in TTS) or 'custom' (external TTS)
LIVEAVATAR_MODE=full
# Language code: en, nl, fr, etc.
LIVEAVATAR_LANGUAGE=en

# Text-to-Speech (required only for CUSTOM mode)
# 'openai' or 'elevenlabs'
TTS_PROVIDER=openai
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Admin Panel — leave empty to disable
ADMIN_PASSWORD=

# API Security — if set, all routes require this as Bearer token
API_SECRET=

# Heroku-only (for admin config management via Heroku Platform API)
HEROKU_API_KEY=
HEROKU_APP_NAME=

# App URL (SSR fallback — browser uses window.location.origin automatically)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default UI (overridable via URL params)
NEXT_PUBLIC_DEFAULT_SITE=
NEXT_PUBLIC_DEFAULT_LANG=

# Customer demo (set by install.sh, used by server.sh)
DEMO_CUSTOMER_URL=
DEMO_BRAND_COLOR=
